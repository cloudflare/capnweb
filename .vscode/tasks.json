{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "validate: Worker dev server",
      "type": "shell",
      "command": "npm run build && cd examples/worker-react && npx wrangler dev --config wrangler.jsonc --ip 127.0.0.1 --port 8787 --inspector-port 9229",
      "isBackground": true,
      "problemMatcher": {
        "owner": "validate-worker",
        "pattern": { "regexp": "$^" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Ready on http://127\\.0\\.0\\.1:8787"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "validate: client dev server",
      "type": "shell",
      "command": "cd examples/worker-react/client && npm install && npm run dev -- --host 127.0.0.1 --port 5173 --strictPort",
      "isBackground": true,
      "problemMatcher": {
        "owner": "validate-client",
        "pattern": { "regexp": "$^" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+http://127\\.0\\.0\\.1:5173/"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
